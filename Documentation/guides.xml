<?xml version="1.0" encoding="UTF-8"?>
<guides xmlns="https://www.phpdoc.org/guides" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://www.phpdoc.org/guides ../vendor/phpdocumentor/guides-cli/resources/schema/guides.xsd"
        links-are-relative="true">
    <extension class="\T3Docs\Typo3DocsTheme\DependencyInjection\Typo3DocsThemeExtension"
               project-home="https://docs.typo3.org"
               project-contact="https://typo3.slack.com/archives/C028JEPJL"
               project-repository="https://github.com/TYPO3-Documentation/DocsTypo3Org-Homepage"
               project-issues="https://github.com/TYPO3-Documentation/DocsTypo3Org-Homepage/issues"
               edit-on-github-branch="main" edit-on-github="TYPO3-Documentation/DocsTypo3Org-Homepage"
               typo3-core-preferred="stable"
               interlink-shortcode="t3docs"
               disable-version-switch="true"
    />
